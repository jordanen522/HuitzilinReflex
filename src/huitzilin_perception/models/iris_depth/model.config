<?xml version="1.0"?>
<model>
  <name>iris_depth</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <description>
    iris_with_standoffs + forward-facing simulated OAK-D Lite depth camera.
    Resolution 640x480, DFOV ~73 deg, 30 fps, range 0.2-19 m, Gaussian noise.
    Sensor frame: camera_optical_frame (Z-forward optical convention, REP-103).
  </description>
</model>
